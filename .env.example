# =============================================================================
# Environment variables — example
# =============================================================================
# Copy to .env and fill in real values:
#   cp .env.example .env


# --- OpenSearch source (basic auth) ---
OPENSEARCH_URL=
OPENSEARCH_INDEX=logs-raw
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_TS_FIELD=timestamp


# --- AWS / S3 sink (CLOUD variant only) ---
# Region and credentials are picked up from the EC2 instance profile in prod.
# For local AWS dev, set AWS_PROFILE or AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY.
AWS_REGION=eu-west-3
S3_RAW_BUCKET=clair-obscur-raw-<account-id>
S3_RAW_PREFIX=logs-raw
S3_META_PREFIX=_meta
S3_BACKFILL_PREFIX=_backfill
S3_CHECKPOINT_PREFIX=_checkpoints/ingestion


# --- ClickHouse sink (LOCAL variant only) ---
# Defaults match the docker-compose.local.yml service name. For host-side
# clickhouse-client/REPL access set CLICKHOUSE_HOST=localhost.
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=clair_obscur


# --- Backfill tuning ---
BACKFILL_WINDOWS=4
BACKFILL_PAGE_SIZE=1000
BACKFILL_CHUNK_BYTES=52428800        # 50 MiB
BACKFILL_PROGRESS_EVERY_PAGES=5


# --- Stream tuning ---
POLL_INTERVAL_SEC=300          # fallback poll interval (sec) when no SQS signal
CHECKPOINT_INTERVAL_MS=60000
FLINK_PARALLELISM=1

# --- SQS event trigger (cloud variant) ---
# Create with: aws sqs create-queue --queue-name clair-obscur-stream-trigger --region eu-west-3
# Leave empty to disable SQS and use plain time-based polling.
STREAM_SQS_QUEUE_URL=


# --- Future: detection layer (kept for the rest of the stack) ---
LLM_PROVIDER=
LLM_API_KEY=

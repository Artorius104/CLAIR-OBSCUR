# =============================================================================
# Environment variables — copy to .env and fill in values
#   cp .env.example .env
# =============================================================================


# --- Data source ---
# Path to the ingestion JSONL files INSIDE the container (matches the volume mount
# target in docker-compose.yml). Change only if you alter the volume target.
DATA_ROOT=/data/ingestion


# --- AWS / S3 ---
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # only for temporary / SSO credentials

# Create bucket: aws s3 mb s3://clair-obscur-raw-<account-id> --region eu-west-3
S3_RAW_BUCKET=clair-obscur-raw-<account-id>
S3_RAW_PREFIX=logs-raw
S3_META_PREFIX=_meta
S3_CHECKPOINT_PREFIX=_checkpoints/ingestion


# --- Tuning ---
CHUNK_BYTES=52428800        # 50 MiB per S3 part
CHECKPOINT_INTERVAL_MS=60000
FLINK_PARALLELISM=1
# Target ingestion rate (records/s). 4100 ≈ 14.7 M records in 1 hour.
# Set to 0 to run at full speed (no throttle).
INGEST_RPS=4100


# --- Detection layer (rest of stack) ---
LLM_PROVIDER=
LLM_API_KEY=


# --- ClickHouse (local on-prem variant, unchanged) ---
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=clair_obscur

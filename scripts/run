#!/usr/bin/env bash
# Dual-mode launcher for the Clair-Obscur pipeline.
#
# USAGE
#   ./scripts/run local up               Start ClickHouse + PyFlink stream (background)
#   ./scripts/run local down             Stop everything; CH data persists in volume
#   ./scripts/run local logs [service]   Tail logs (default: all services)
#   ./scripts/run local sql              Open a clickhouse-client REPL
#
#   ./scripts/run cloud ingest           Setup S3 bucket + IAM policy, then start ingestion (~1 h)
#   ./scripts/run cloud ingest-stop      Stop a running ingestion container
#   ./scripts/run cloud status           Show ingestion progress + last checkpoint from S3
#   ./scripts/run cloud logs             Tail the running stream-worker container
# END USAGE

set -euo pipefail
# Resolve repo root: this script lives in <repo>/scripts/, so go one level up.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
cd "$REPO_ROOT"

LOCAL_COMPOSE="src/backend/streaming/docker-compose.local.yml"
CLOUD_COMPOSE="src/backend/streaming/docker-compose.yml"

TARGET="${1:-help}"; shift || true
CMD="${1:-help}";    shift || true

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

usage() { sed -n '/^# USAGE/,/^# END USAGE/p' "$0" | sed 's/^# \{0,1\}//'; }

# Load .env and export all variables into the current shell.
_load_env() {
  if [ ! -f ".env" ]; then
    echo "error: .env not found — run: cp .env.example .env and fill in values" >&2
    exit 1
  fi
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
  REGION="${AWS_REGION:-eu-west-3}"
  BUCKET="${S3_RAW_BUCKET:-}"
  META_PREFIX="${S3_META_PREFIX:-_meta}"
  if [ -z "$BUCKET" ]; then
    echo "error: S3_RAW_BUCKET is not set in .env" >&2
    exit 1
  fi
}

# Create the S3 bucket if it does not exist, then apply security hardening
# idempotently (safe to re-run on an existing bucket).
_ensure_bucket() {
  echo "==> Checking s3://${BUCKET} in ${REGION}..."
  if ! aws s3api head-bucket --bucket "$BUCKET" --region "$REGION" 2>/dev/null; then
    echo "    Creating bucket..."
    if [ "$REGION" = "us-east-1" ]; then
      aws s3api create-bucket --bucket "$BUCKET" --region "$REGION"
    else
      aws s3api create-bucket \
        --bucket "$BUCKET" \
        --region "$REGION" \
        --create-bucket-configuration "LocationConstraint=${REGION}"
    fi
    echo "    Bucket created."
  else
    echo "    Bucket already exists."
  fi

  # Hardening — idempotent, applied on every run.
  aws s3api put-public-access-block --bucket "$BUCKET" \
    --public-access-block-configuration \
    "BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true"

  aws s3api put-bucket-versioning \
    --bucket "$BUCKET" \
    --versioning-configuration Status=Enabled

  aws s3api put-bucket-encryption --bucket "$BUCKET" \
    --server-side-encryption-configuration \
    '{"Rules":[{"ApplyServerSideEncryptionByDefault":{"SSEAlgorithm":"AES256"},"BucketKeyEnabled":true}]}'

  echo "    Bucket secured (public access blocked, versioning on, AES-256)."
}

# Attach an inline S3 policy to the current IAM identity so the job can
# write to the bucket.  Skipped if the caller is an assumed role (instance
# profile, SSO) — those already carry permissions via their trust policy.
_ensure_iam_policy() {
  echo "==> Checking IAM write access to s3://${BUCKET}..."

  # Detect caller type: IAM user vs assumed-role/SSO.
  CALLER_ARN="$(aws sts get-caller-identity --query Arn --output text)"
  CALLER_TYPE="$(echo "$CALLER_ARN" | awk -F: '{print $6}' | cut -d/ -f1)"

  if [ "$CALLER_TYPE" != "user" ]; then
    echo "    Caller is a role/SSO session (${CALLER_ARN}) — skipping inline policy attachment."
    echo "    Make sure the role has s3:PutObject / s3:GetObject on arn:aws:s3:::${BUCKET}/*"
    return
  fi

  USERNAME="$(echo "$CALLER_ARN" | awk -F/ '{print $NF}')"
  POLICY_NAME="clair-obscur-s3-ingest-${BUCKET}"

  POLICY_DOC="{
    \"Version\": \"2012-10-17\",
    \"Statement\": [
      {
        \"Effect\": \"Allow\",
        \"Action\": [
          \"s3:PutObject\",
          \"s3:GetObject\",
          \"s3:DeleteObject\",
          \"s3:AbortMultipartUpload\",
          \"s3:ListMultipartUploadParts\"
        ],
        \"Resource\": \"arn:aws:s3:::${BUCKET}/*\"
      },
      {
        \"Effect\": \"Allow\",
        \"Action\": [\"s3:ListBucket\", \"s3:GetBucketLocation\"],
        \"Resource\": \"arn:aws:s3:::${BUCKET}\"
      }
    ]
  }"

  aws iam put-user-policy \
    --user-name "$USERNAME" \
    --policy-name "$POLICY_NAME" \
    --policy-document "$POLICY_DOC" 2>/dev/null && \
    echo "    Inline policy '${POLICY_NAME}' attached to IAM user '${USERNAME}'." || \
    echo "    Could not attach IAM policy (iam:PutUserPolicy denied). Skipping — ensure S3 access exists."
}

# Verify the job can actually write a test object to the bucket.
_verify_s3_access() {
  echo "==> Verifying S3 write access..."
  if echo '{"test":true}' | aws s3 cp - "s3://${BUCKET}/${META_PREFIX}/.write_test" --quiet; then
    aws s3 rm "s3://${BUCKET}/${META_PREFIX}/.write_test" --quiet
    echo "    S3 write access confirmed."
  else
    echo "error: Cannot write to s3://${BUCKET} — check IAM permissions." >&2
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

case "$TARGET:$CMD" in

  # ---- LOCAL ---------------------------------------------------------------

  local:up)
    export HOST_DATA_ROOT="${REPO_ROOT}/data/dataset_finale/ingestion"
    exec docker compose -f "$LOCAL_COMPOSE" up -d --build
    ;;
  local:down)
    export HOST_DATA_ROOT="${REPO_ROOT}/data/dataset_finale/ingestion"
    exec docker compose -f "$LOCAL_COMPOSE" down
    ;;
  local:logs)
    export HOST_DATA_ROOT="${REPO_ROOT}/data/dataset_finale/ingestion"
    exec docker compose -f "$LOCAL_COMPOSE" logs -f "$@"
    ;;
  local:sql)
    exec docker compose -f "$LOCAL_COMPOSE" exec clickhouse \
      clickhouse-client --database clair_obscur
    ;;

  # ---- CLOUD ---------------------------------------------------------------

  cloud:ingest)
    _load_env

    echo ""
    echo "========================================================"
    echo "  Clair-Obscur — Cloud Ingestion Setup"
    echo "========================================================"
    echo ""

    # 1. Verify AWS identity.
    echo "==> AWS identity"
    aws sts get-caller-identity
    echo ""

    # 2. Create S3 bucket with security settings.
    _ensure_bucket
    echo ""

    # 3. Attach IAM write policy to the current user (if applicable).
    _ensure_iam_policy
    echo ""

    # 4. Sanity-check: try writing a test object.
    _verify_s3_access
    echo ""

    # 5. Build + start the ingestion container.
    export HOST_DATA_ROOT="${REPO_ROOT}/data/dataset_finale/ingestion"
    echo "==> Starting stream-worker (target ~30 min, INGEST_RPS=${INGEST_RPS:-8200})"
    echo "    Source : ${HOST_DATA_ROOT}"
    echo "    Sink   : s3://${BUCKET}/${S3_RAW_PREFIX:-logs-raw}/"
    echo "    Progress checkpoint: s3://${BUCKET}/${META_PREFIX}/ingest_progress.json"
    echo ""

    docker compose -f "$CLOUD_COMPOSE" --env-file ".env" up -d --build

    echo ""
    echo "Ingestion started. Following logs — Ctrl+C to detach (job keeps running)."
    echo "Check progress anytime with:  ./scripts/run cloud status"
    echo ""
    exec docker compose -f "$CLOUD_COMPOSE" logs -f
    ;;

  cloud:ingest-stop)
    _load_env
    export HOST_DATA_ROOT="${REPO_ROOT}/data/dataset_finale/ingestion"
    echo "==> Stopping stream-worker..."
    docker compose -f "$CLOUD_COMPOSE" --env-file ".env" down
    ;;

  cloud:logs)
    _load_env
    export HOST_DATA_ROOT="${REPO_ROOT}/data/dataset_finale/ingestion"
    exec docker compose -f "$CLOUD_COMPOSE" logs -f
    ;;

  cloud:status)
    _load_env
    export HOST_DATA_ROOT="${REPO_ROOT}/data/dataset_finale/ingestion"
    echo ""
    echo "==> AWS identity"
    aws sts get-caller-identity --output table
    echo ""

    echo "==> Ingestion progress  (s3://${BUCKET}/${META_PREFIX}/ingest_progress.json)"
    aws s3 cp "s3://${BUCKET}/${META_PREFIX}/ingest_progress.json" - 2>/dev/null \
      | python3 -c "
import json, sys
d    = json.load(sys.stdin)
docs  = d.get('total_docs', 0)
parts = d.get('parts_written', 0)
elaps = d.get('elapsed_sec', 0)
rps   = d.get('rate_rps', docs / max(elaps, 1))
upd   = d.get('updated_at', '?')
total = 14_721_375
pct   = docs / total * 100
eta   = (total - docs) / max(rps, 1)
print(f'  Docs sent  : {docs:,} / {total:,}  ({pct:.1f}%)')
print(f'  Parts on S3: {parts}')
print(f'  Elapsed    : {elaps:.0f}s  ({elaps/60:.1f} min)')
print(f'  Rate       : {rps:.0f} rec/s')
print(f'  ETA        : ~{eta/60:.0f} min remaining')
print(f'  Updated at : {upd}')
" 2>/dev/null || echo "    (not found — ingestion not started yet)"

    echo ""
    echo "==> Latest S3 parts written"
    aws s3 ls "s3://${BUCKET}/${S3_RAW_PREFIX:-logs-raw}/" \
      --recursive --human-readable 2>/dev/null \
      | sort | tail -8 \
      || echo "    (no files yet)"

    echo ""
    echo "==> Flink checkpoint directory"
    aws s3 ls "s3://${BUCKET}/${S3_CHECKPOINT_PREFIX:-_checkpoints/ingestion}/" \
      --human-readable 2>/dev/null | tail -5 \
      || echo "    (no checkpoints yet)"

    echo ""
    echo "==> Container status"
    HOST_DATA_ROOT="${REPO_ROOT}/data/dataset_finale/ingestion" \
      docker compose -f "$CLOUD_COMPOSE" ps 2>/dev/null || echo "    (not running)"
    ;;

  *|help:*|:*)
    usage
    [ "$TARGET" != "help" ] && exit 1 || exit 0
    ;;
esac
